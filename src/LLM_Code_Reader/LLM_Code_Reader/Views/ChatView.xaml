<UserControl x:Class="LLM_Code_Reader.Views.ChatView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LLM_Code_Reader.Views"
        xmlns:viewmodels="clr-namespace:LLM_Code_Reader.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:ChatViewModel}"
        mc:Ignorable="d"
        Height="810" Width="1400" >

    <Grid Background="Azure">

        <!-- Section de discussion -->
        <ListBox ItemsSource="{Binding Messages}" Margin="143,10,28,107" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Sender}" FontWeight="Bold" Foreground="DarkBlue"/>
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="5,2,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Section d'input -->
        <TextBox HorizontalAlignment="Left" Margin="527,714,0,0" TextWrapping="Wrap" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="722" Height="86"/>
        <Button Content="Fichier" Command="{Binding CommandeSendFile}" HorizontalAlignment="Left" Margin="1271,762,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.294,0.367" Width="48" Height="34"/>
        <Button Content="Envoyer" Command="{Binding CommandeSendMessage}" HorizontalAlignment="Left" Margin="1271,715,0,0" VerticalAlignment="Top" Width="101" Height="42"/>
        <Button Content="Dossier" Command="{Binding CommandeSendFolder}" HorizontalAlignment="Left" Margin="1324,762,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.294,0.367" Width="48" Height="34"/>

        <!-- Options/Controles -->
        <ComboBox ItemsSource="{Binding ModelList}" SelectedItem="{Binding SelectedModel}" HorizontalAlignment="Left" Margin="10,36,0,0" VerticalAlignment="Top" Width="120"/>
        <Button Content="Démarrer" HorizontalAlignment="Left" Margin="10,69,0,0" VerticalAlignment="Top" Width="120" Command="{Binding CommandeCreateConnector}" Height="31"/>
        <Button Content="Arrêter" HorizontalAlignment="Left" Margin="10,105,0,0" VerticalAlignment="Top" Width="120" Command="{Binding CommandeStopChat}" Height="31"/>
        <CheckBox Content="Contexte élevé?" IsChecked="{Binding HighCtx}" IsEnabled="{Binding IsNotActive}" HorizontalAlignment="Left" Margin="10,141,0,0" VerticalAlignment="Top"/>
        <Label Content="Modèle" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>

    </Grid>
</UserControl>
